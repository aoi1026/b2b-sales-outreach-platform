DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/MVP_business_message?schema=public"
SESSION_SECRET="replace-with-64-char-random-string"

# iProyal proxy (https://iproyal.com) — residential proxy for form submission
PROXY_SERVER="http://geo.iproyal.com:12321"
PROXY_USERNAME="your-iproyal-username"
PROXY_PASSWORD="your-iproyal-password_country-jp"

# 2captcha (https://2captcha.com) — CAPTCHA solving service
# Supports reCAPTCHA v2 / v3 (incl. Enterprise) and Cloudflare Turnstile.
# Leave blank to skip CAPTCHA solving.
TWOCAPTCHA_API_KEY="your-2captcha-api-key"
